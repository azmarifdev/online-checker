<%- include('partials/header') %>

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-2">Device Tracker Dashboard</h1>
    <p class="text-gray-600">
        Monitoring activity for:
        <span class="font-semibold"><%= deviceName %></span>
    </p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <!-- Current Status Card -->
    <div class="bg-white rounded-lg shadow-md p-6 card-hover">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-gray-700">Current Status</h2>
            <% if (isOnline) { %>
            <div class="h-3 w-3 bg-green-400 rounded-full online-pulse"></div>
            <% } else { %>
            <div class="h-3 w-3 bg-red-500 rounded-full"></div>
            <% } %>
        </div>
        <div class="text-center py-4">
            <div
                class="inline-block p-4 rounded-full <%= isOnline ? 'bg-green-100 text-green-500' : 'bg-red-100 text-red-500' %> mb-3">
                <i class="fas <%= isOnline ? 'fa-wifi' : 'fa-wifi-slash' %> text-3xl"></i>
            </div>
            <h3 class="text-2xl font-bold <%= isOnline ? 'text-green-500' : 'text-red-500' %>">
                <%= isOnline ? 'ONLINE' : 'OFFLINE' %>
            </h3>
        </div>
        <% if (currentSession) { %>
        <div class="mt-3 text-sm text-gray-600">
            <p>
                <i class="far fa-clock mr-2"></i>
                Online since: <%= currentSession.onlineTime %>
            </p>
            <p class="mt-1">
                <i class="fas fa-hourglass-half mr-2"></i>
                Current duration: <%= currentSession.duration %>
            </p>
        </div>
        <% } %>
    </div>

    <!-- Daily Summary Card -->
    <div class="bg-white rounded-lg shadow-md p-6 card-hover">
        <h2 class="text-xl font-semibold text-gray-700 mb-4">Today's Summary</h2>
        <div class="flex flex-col items-center py-4">
            <div class="text-center mb-4">
                <span class="text-4xl font-bold text-indigo-500"><%= totalSessions %></span>
                <p class="text-gray-500 mt-1">Sessions today</p>
            </div>
            <div class="h-12 border-l-2 border-gray-200"></div>
            <div class="text-center mt-4">
                <span class="text-4xl font-bold text-indigo-500"><%= totalTime %></span>
                <p class="text-gray-500 mt-1">Total online time</p>
            </div>
        </div>
    </div>

    <!-- Quick Actions Card -->
    <div class="bg-white rounded-lg shadow-md p-6 card-hover">
        <h2 class="text-xl font-semibold text-gray-700 mb-4">Quick Actions</h2>
        <div class="flex flex-col space-y-3">
            <a
                href="/history"
                class="bg-indigo-500 text-white py-2 px-4 rounded flex items-center justify-center hover:bg-indigo-600 transition-colors">
                <i class="fas fa-history mr-2"></i>
                View History
            </a>
            <a
                href="#"
                id="refreshStatusBtn"
                class="bg-gray-200 text-gray-700 py-2 px-4 rounded flex items-center justify-center hover:bg-gray-300 transition-colors">
                <i class="fas fa-sync-alt mr-2"></i>
                Refresh Status
            </a>
            <a
                href="/api/sessions/daily"
                target="_blank"
                class="bg-gray-200 text-gray-700 py-2 px-4 rounded flex items-center justify-center hover:bg-gray-300 transition-colors">
                <i class="fas fa-file-export mr-2"></i>
                Export Today's Data
            </a>
        </div>
    </div>
</div>

<!-- Today's Sessions Table -->
<div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-700 mb-4">Today's Sessions</h2>
    <% if (todaySessions && todaySessions.length > 0) { %>
    <div class="overflow-x-auto">
        <table class="min-w-full">
            <thead>
                <tr class="bg-gray-100">
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Online Time
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Offline Time
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <% todaySessions.forEach(session => { %>
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= session.onlineTime %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= session.offlineTime %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= session.duration %></td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <% if (session.isActive) { %>
                        <span
                            class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                            Active
                        </span>
                        <% } else { %>
                        <span
                            class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                            Ended
                        </span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="text-center py-8 text-gray-500">
        <i class="fas fa-calendar-day text-4xl mb-3"></i>
        <p>No sessions recorded today</p>
    </div>
    <% } %>
</div>

<script>
    // Real-time status update
    document.getElementById('refreshStatusBtn').addEventListener('click', function (e) {
        e.preventDefault();
        fetch('/api/status')
            .then((response) => response.json())
            .then((data) => {
                if (data) {
                    // We should reload the page to get updated data
                    location.reload();
                }
            })
            .catch((error) => console.error('Error fetching status:', error));
    });

    // Auto-refresh every 60 seconds
    setTimeout(() => {
        location.reload();
    }, 60000);
</script>

<%- include('partials/footer') %>
