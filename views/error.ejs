<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Error | Device Tracker</title>
        <!-- Tailwind CSS via CDN -->
        <script src="https://cdn.tailwindcss.com"></script>
        <!-- Font Awesome for icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
    </head>
    <body class="bg-gray-50 flex flex-col min-h-screen">
        <div class="container mx-auto px-4 py-16 flex-grow flex items-center justify-center">
            <div class="bg-white p-8 rounded-lg shadow-lg max-w-lg w-full text-center">
                <div class="text-red-500 text-7xl mb-4">
                    <i class="fas fa-exclamation-circle"></i>
                </div>
                <h1 class="text-3xl font-bold text-red-600 mb-4"><%= message %></h1>
                <% if (error && error.status) { %>
                <p class="text-gray-700 text-xl mb-6">Status: <%= error.status %></p>
                <% } %>
                <p class="text-gray-600 mb-8">Something went wrong. Please try again or contact the administrator.</p>
                <div class="flex space-x-4 justify-center">
                    <a href="/" class="bg-indigo-500 text-white py-2 px-6 rounded-lg hover:bg-indigo-600 transition-colors">
                        <i class="fas fa-home mr-2"></i>
                        Go to Dashboard
                    </a>
                    <button
                        onclick="window.history.back()"
                        class="bg-gray-200 text-gray-700 py-2 px-6 rounded-lg hover:bg-gray-300 transition-colors">
                        <i class="fas fa-arrow-left mr-2"></i>
                        Go Back
                    </button>
                </div>
            </div>
        </div>

        <footer class="bg-gray-800 text-white py-4 mt-auto">
            <div class="container mx-auto px-4 text-center">
                <p>© <%= new Date().getFullYear() %> Device Tracker</p>
                <p class="text-gray-400 text-sm mt-1">
                    <i class="fas fa-exclamation-triangle mr-1"></i>
                    Error encountered
                </p>
            </div>
        </footer>
    </body>
</html>
