<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %> | Device Tracker</title>
        <!-- Tailwind CSS via CDN for simplicity -->
        <script src="https://cdn.tailwindcss.com"></script>
        <!-- Font Awesome for icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
        <!-- Custom styles -->
        <style>
            .online-pulse {
                animation: pulse 2s infinite;
            }
            @keyframes pulse {
                0% {
                    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);
                }
                70% {
                    box-shadow: 0 0 0 10px rgba(74, 222, 128, 0);
                }
                100% {
                    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);
                }
            }
            .card-hover {
                transition: all 0.3s ease;
            }
            .card-hover:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            }
        </style>
        <!-- Custom script -->
        <script>
            function formatDuration(minutes) {
                if (minutes < 1) return 'Less than a minute';
                const hours = Math.floor(minutes / 60);
                const mins = minutes % 60;
                let result = '';
                if (hours > 0) {
                    result += `${hours} hour${hours > 1 ? 's' : ''}`;
                }
                if (mins > 0) {
                    result += `${hours > 0 ? ' ' : ''}${mins} minute${mins > 1 ? 's' : ''}`;
                }
                return result;
            }
        </script>
    </head>
    <body class="bg-gray-50 flex flex-col min-h-screen">
        <!-- Navigation -->
        <nav class="bg-indigo-600 text-white shadow-md">
            <div class="container mx-auto px-4 py-3">
                <div class="flex justify-between items-center">
                    <div class="flex items-center space-x-2">
                        <i class="fas fa-wifi text-2xl"></i>
                        <a href="/" class="text-xl font-bold">Device Tracker</a>
                    </div>
                    <div class="flex items-center space-x-6">
                        <a href="/" class="hover:text-indigo-200 transition-colors">
                            <i class="fas fa-home mr-1"></i>
                            Dashboard
                        </a>
                        <a href="/history" class="hover:text-indigo-200 transition-colors">
                            <i class="fas fa-history mr-1"></i>
                            History
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="container mx-auto px-4 py-6 flex-grow"><%- body %></main>

        <!-- Footer -->
        <footer class="bg-gray-800 text-white py-4 mt-auto">
            <div class="container mx-auto px-4 text-center">
                <p>
                    © <%= new Date().getFullYear() %> Device Tracker | Target Device: <%= process.env.TARGET_DEVICE_NAME %>
                </p>
                <p class="text-gray-400 text-sm mt-1">
                    <i class="fas fa-signal mr-1"></i>
                    Router: <%= process.env.ROUTER_IP %> |
                    <i class="fas fa-wifi mr-1"></i>
                    MAC: <%= process.env.TARGET_MAC %>
                </p>
            </div>
        </footer>
    </body>
</html>
